# /etc/wtg/wtg.env — WTG 환경 변수 (운영 머신용 샘플)
#
# 설치 :
#   sudo cp deploy/systemd/wtg.env.sample /etc/wtg/wtg.env
#   sudo chmod 600 /etc/wtg/wtg.env
#   sudo chown root:wtg /etc/wtg/wtg.env
#
# 변경 후 :
#   sudo systemctl restart 'wtg-*'

# 환경 라벨 (운영 / 스테이징 / 개발)
WTG_ENV=prod

# === etcd cluster ===
WTG_ETCD=https://etcd1.internal:2379,https://etcd2.internal:2379,https://etcd3.internal:2379
WTG_ETCD_TLS_CA=/etc/pki/wtg/ca.crt
WTG_ETCD_TLS_CERT=/etc/pki/wtg/int.crt
WTG_ETCD_TLS_KEY=/etc/pki/wtg/int.key

# === broker (mymqd active-standby) ===
# 주의 : flag 는 host/port 분리. active-standby 는 broker-VIP 또는 DNS
# round-robin 으로 active 만 보이게 둠. cluster 전환 시 supervisor
# goroutine 이 자동 재연결 (docs/broker-reconnect.md).
WTG_BROKER_HOST=broker-vip.internal
WTG_BROKER_PORT=11217
WTG_BROKER_TLS_CA=/etc/pki/wtg/ca.crt
WTG_BROKER_TLS_CERT=/etc/pki/wtg/int.crt
WTG_BROKER_TLS_KEY=/etc/pki/wtg/int.key

# === Redis Sentinel (세션 / cookie_t) — mci-api 용 ===
# mci-admin / mci-price 는 Redis 직접 사용 안 함 (admin 은 etcd, price 는 quoteid-redis)
WTG_API_REDIS=redis1.internal:26379,redis2.internal:26379,redis3.internal:26379
WTG_API_REDIS_MASTER=wtg-auth-master

# === Redis (quoteid Registry) — 본 시나리오는 세션 Redis 와 instance 분리 ===
WTG_QUOTEID_REDIS=redis1.internal:26379,redis2.internal:26379,redis3.internal:26379
WTG_QUOTEID_REDIS_MASTER=wtg-quoteid-master
WTG_QUOTEID_INSTANCE=int1     # int2 호스트는 int2 로 변경

# === 관측 stack ===
WTG_OTEL_ENDPOINT=otel-col.obs1.internal:4317
WTG_PROM_URL=http://prom.obs1.internal:9091
WTG_GRAFANA_URL=http://grafana.obs1.internal:3000
WTG_GRAFANA_USER=wtg-readonly
# 주의: plain password — env 파일은 mode 0600 + root:wtg 강제.
# 시크릿 manager (Vault 등) 도입 시 sd-creds 패턴 권장.
WTG_GRAFANA_PASS=__set_at_install__

# === TimescaleDB (mci-chart + mci-price Archiver) ===
WTG_DSN=postgres://wtg:secret@db1.internal/wtg?sslmode=require

# === 단순화 v3 — 본 환경에서 끄는 feature ===
# (현재 systemd unit 에는 미반영 — 활성하려면 ExecStart 에 추가)
WTG_ENABLE_SWAP_LOCK=false    # swap 거래 안 함 → mci-price 의 --enable-swap-lock 빼면 default false
WTG_CUSTOMER_STREAM=true      # 5L customer quote 활성 (off 면 mci-edge-price --customer-stream 빼기)
WTG_QUOTE_STREAM=true         # Profile customer quote 활성

# === 시크릿 ===
# 절대 git 에 commit 하지 말 것. /etc/wtg/wtg.env 는 mode 0600 + root:wtg.
WTG_JWT_SIGNING_KEY=/etc/pki/wtg/jwt-signing.key
WTG_PUSH_SECRET=/etc/pki/wtg/push-secret
